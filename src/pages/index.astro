---
import { getEntry } from 'astro:content';
import AcquisitionCTA from '../components/AcquisitionCTA.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import { SITE } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteEntry = await getEntry('site', 'default');
if (!siteEntry) throw new Error('Site config missing');
const siteConfig = siteEntry.data;
---

<BaseLayout>
  <Nav />

  <main>
    <!-- HERO -->
    <header class="hero-bg min-h-[100dvh] flex items-center pt-16 relative">
      <div class="max-w-screen-xl mx-auto px-6 pt-12 pb-20">
        <div class="max-w-5xl">
          <!-- Badge -->
          <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-3xl bg-white/10 backdrop-blur-md border border-white/20 mb-8">
            <div class="flex items-center gap-x-1.5">
              <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
              <span class="text-emerald-400 text-xs font-semibold tracking-[1.5px] uppercase">Premium .com • Available Now</span>
            </div>
          </div>

          <div class="max-w-4xl">
            <h1 class="font-display text-[3.75rem] md:text-[5.5rem] leading-[0.92] tracking-[-4px] font-extrabold mb-2">
              <span class="gold-gradient">Genius Salt</span><br />
              <span class="text-4xl md:text-5xl text-white tracking-tight">.com</span>
            </h1>

            <p class="text-2xl md:text-3xl text-white font-serif-display font-semibold tracking-tight mt-2 mb-3 italic">
              The Essential Seasoning of Genius
            </p>

            <p class="max-w-2xl text-xl md:text-2xl text-zinc-400 font-light tracking-tight leading-tight mb-10">
              Premium Brandable Domain — where the spark of brilliance meets the grounding mineral that gives it lasting form. Available for strategic acquisition.
            </p>
          </div>

          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <AcquisitionCTA label="Secure This Domain" variant="white" icon="fa-arrow-right-long" />
            <a href="#concept" class="px-8 py-4 border border-white/30 hover:bg-white/5 active:bg-white/10 transition-all font-semibold text-lg rounded-3xl flex items-center justify-center gap-x-2 w-full sm:w-auto text-white no-underline">
              <span>Explore the Meaning</span>
            </a>
          </div>

          <div class="mt-10 flex items-center gap-x-8 text-sm">
            <div class="flex items-center gap-x-2 text-zinc-400">
              <i class="fa-solid fa-check text-emerald-400"></i>
              <span>Multi-Layered Brand Depth</span>
            </div>
            <div class="flex items-center gap-x-2 text-zinc-400">
              <i class="fa-solid fa-check text-emerald-400"></i>
              <span>Instant Authority & Ambition</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 hidden lg:block">
        <div class="flex flex-col items-center text-xs tracking-[2px] text-zinc-500">
          <span>SCROLL TO EXPLORE</span>
          <i class="fa-solid fa-chevron-down mt-1.5 animate-bounce"></i>
        </div>
      </div>
    </header>

    <!-- TRUST BAR -->
    <div class="border-b border-zinc-800 bg-zinc-900/60 py-5">
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="flex flex-wrap justify-center md:justify-between items-center gap-x-8 gap-y-3 text-sm">
          {
            siteConfig.trustPoints.map((point) => (
              <div class="flex items-center gap-x-2 text-zinc-400">
                <i class="fa-solid fa-circle-check text-amber-400"></i>
                <span class="font-medium">{point}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- THE CONCEPT -->
    <section id="concept" class="max-w-screen-xl mx-auto px-6 pt-20 pb-16">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-14">
          <div class="inline-block px-4 py-1 rounded-3xl bg-amber-400/10 text-amber-400 text-xs font-bold tracking-[2px] mb-4">THE CONCEPT</div>
          <h2 class="section-header tracking-[-2.5px]">Where Genius Meets<br /><span class="gold-gradient">Its Essential Foundation</span></h2>
        </div>

        <div class="grid md:grid-cols-2 gap-12 items-start">
          <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-10">
            <div class="text-sm uppercase tracking-[2px] text-zinc-500 mb-6">GENIUS</div>
            <p class="text-zinc-300 leading-relaxed text-lg">
              From the Latin <em class="text-amber-300">genius</em>, originally a tutelary spirit or the innate, divine quality residing within a person or place. Today it signifies exceptional intellectual or creative power: the rare capacity for original insight, profound innovation, and transformative achievement.
            </p>
          </div>

          <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-10">
            <div class="text-sm uppercase tracking-[2px] text-zinc-500 mb-6">SALT</div>
            <p class="text-zinc-300 leading-relaxed text-lg">
              The foundational mineral (NaCl) that seasons, preserves, and sustains life. In language and culture, "salt" has long also meant <strong class="text-white">wit, essence, and the indispensable element</strong> that brings out true flavor.
            </p>
          </div>
        </div>

        <div class="mt-12 bg-gradient-to-r from-amber-950/30 via-zinc-900 to-amber-950/30 border border-zinc-800 rounded-3xl p-10 text-center">
          <p class="text-xl md:text-2xl text-zinc-200 leading-relaxed font-serif-display italic">
            Genius Salt unites these forces into a name of rare power. It suggests the <strong class="text-amber-300 font-bold not-italic">essential catalyst</strong> that ignites and sustains genius, the <strong class="text-amber-300 font-bold not-italic">grounding mineral</strong> that gives lasting form to the spark of brilliance, and the <strong class="text-amber-300 font-bold not-italic">precise seasoning</strong> that makes exceptional thought not only possible but vivid, usable, and enduring.
          </p>
        </div>
      </div>
    </section>

    <!-- PHILOSOPHICAL & CULTURAL RESONANCE -->
    <section id="philosophy" class="bg-zinc-900 border-y border-zinc-800 py-20">
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-14">
            <div class="inline-block px-4 py-1 rounded-3xl bg-emerald-400/10 text-emerald-400 text-xs font-bold tracking-[2px] mb-4">PHILOSOPHICAL &amp; CULTURAL RESONANCE</div>
            <h2 class="section-header tracking-[-2.5px]">The Ancient Tension<br /><span class="gold-gradient">Between Spark and Form</span></h2>
          </div>

          <div class="prose-custom space-y-5 text-lg">
            <p>
              Throughout history, genius has been viewed as both a bestowed gift and something that can be honored, cultivated, or lost. The Roman concept of <em class="text-amber-300">genius</em> was an indwelling spirit — a personal deity that required the right conditions to thrive. In alchemical traditions, the volatile "spirit" or spark finds its fixed counterpart in <strong>Salt</strong> — the principle of embodiment, crystallization, and permanence.
            </p>

            <p>
              Genius Salt captures this ancient tension beautifully: the <strong>divine spark</strong> (genius) given material reality and staying power through the right foundational elements (salt). It speaks to the idea that true genius is not merely lightning in a bottle, but lightning <strong class="text-white">preserved, seasoned, and channeled</strong> into lasting creation.
            </p>

            <p>
              In everyday language, "salt" also denotes sharp wit and lively intelligence. Thus the name carries an additional layer — the seasoning that makes genius not only profound, but <strong class="text-white">sparkling, memorable, and alive</strong> in conversation and culture.
            </p>
          </div>

          <div class="mt-12 grid sm:grid-cols-3 gap-6">
            <div class="insight-card bg-zinc-950 border border-zinc-800 rounded-2xl p-8 text-center">
              <div class="text-amber-400 text-3xl mb-3"><i class="fa-solid fa-bolt"></i></div>
              <h3 class="font-semibold text-lg mb-2">The Spark</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">Divine inspiration, the flash of original insight, the lightning strike of creativity.</p>
            </div>
            <div class="insight-card bg-zinc-950 border border-zinc-800 rounded-2xl p-8 text-center">
              <div class="text-amber-400 text-3xl mb-3"><i class="fa-solid fa-cube"></i></div>
              <h3 class="font-semibold text-lg mb-2">The Form</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">Crystallization, embodiment, the material reality that makes brilliance tangible and lasting.</p>
            </div>
            <div class="insight-card bg-zinc-950 border border-zinc-800 rounded-2xl p-8 text-center">
              <div class="text-amber-400 text-3xl mb-3"><i class="fa-solid fa-droplet"></i></div>
              <h3 class="font-semibold text-lg mb-2">The Essence</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">The seasoning that brings out true flavor — making genius vivid, usable, and alive in the world.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- THE SCIENCE -->
    <section id="science" class="max-w-screen-xl mx-auto px-6 pt-20 pb-16">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-14">
          <div class="inline-block px-4 py-1 rounded-3xl bg-amber-400/10 text-amber-400 text-xs font-bold tracking-[2px] mb-4">THE SCIENCE</div>
          <h2 class="section-header tracking-[-2.5px]">Cultivating<br /><span class="gold-gradient">Exceptional Minds</span></h2>
          <p class="mt-4 text-xl text-zinc-400">Modern neuroscience reveals the biochemical foundations of peak cognitive output.</p>
        </div>

        <div class="prose-custom space-y-5 text-lg">
          <p>
            While genetics contribute to cognitive potential, modern neuroscience shows that the expression of genius-level performance — sustained focus, creative insight, rapid problem-solving, and flow states — is profoundly influenced by brain chemistry and physiology.
          </p>
        </div>

        <div class="mt-12 grid md:grid-cols-3 gap-6">
          <div class="card-hover bg-zinc-900 border border-zinc-800 rounded-3xl p-8 flex flex-col">
            <div class="w-12 h-12 flex items-center justify-center rounded-2xl gold-glow bg-opacity-10 mb-6">
              <i class="fa-solid fa-brain text-zinc-950 text-xl"></i>
            </div>
            <h3 class="font-semibold text-xl tracking-tight mb-3">Neurotransmitter Balance</h3>
            <p class="text-zinc-400 leading-relaxed flex-grow">Precise dopamine for motivation and idea generation, acetylcholine for memory and creative association, norepinephrine for attention and drive.</p>
          </div>

          <div class="card-hover bg-zinc-900 border border-zinc-800 rounded-3xl p-8 flex flex-col">
            <div class="w-12 h-12 flex items-center justify-center rounded-2xl gold-glow bg-opacity-10 mb-6">
              <i class="fa-solid fa-bolt-lightning text-zinc-950 text-xl"></i>
            </div>
            <h3 class="font-semibold text-xl tracking-tight mb-3">Electrolyte &amp; Mineral Status</h3>
            <p class="text-zinc-400 leading-relaxed flex-grow">Optimal electrolyte and mineral balance for efficient neuronal firing and energy metabolism — the literal "salts" of cognition.</p>
          </div>

          <div class="card-hover bg-zinc-900 border border-zinc-800 rounded-3xl p-8 flex flex-col">
            <div class="w-12 h-12 flex items-center justify-center rounded-2xl gold-glow bg-opacity-10 mb-6">
              <i class="fa-solid fa-shield-halved text-zinc-950 text-xl"></i>
            </div>
            <h3 class="font-semibold text-xl tracking-tight mb-3">Neuroprotective Nutrients</h3>
            <p class="text-zinc-400 leading-relaxed flex-grow">Compounds that support long-term brain health and plasticity, ensuring cognitive resilience across a lifetime of peak performance.</p>
          </div>
        </div>

        <div class="mt-12 bg-zinc-900 border border-zinc-800 rounded-3xl p-10">
          <p class="text-lg text-zinc-300 leading-relaxed">
            High performers and historically recognized "geniuses" have often intuitively managed these factors — through diet, stimulants, environment, and rigorous self-care. Today we understand this more clearly: the right "salts" and foundational nutrients help create the internal conditions where <strong class="text-white">exceptional thinking becomes reliable rather than sporadic</strong>.
          </p>
          <p class="mt-5 text-lg text-zinc-300 leading-relaxed">
            Genius Salt is therefore a conceptually perfect name for ventures at the frontier of human performance: the <strong class="text-amber-300">precise seasoning and biochemical foundation</strong> that allows genius to emerge, stabilize, and scale.
          </p>
        </div>
      </div>
    </section>

    <!-- WHY PREMIUM -->
    <section id="why-premium" class="bg-zinc-900 border-y border-zinc-800 py-20">
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-14">
          <div class="inline-block px-4 py-1 rounded-3xl bg-amber-400/10 text-amber-400 text-xs font-bold tracking-[2px] mb-4">PREMIUM ASSET</div>
          <h2 class="section-header tracking-[-2.5px]">Why geniussalt.com<br />commands a <span class="gold-gradient">premium acquisition price</span></h2>
          <p class="mt-5 text-xl text-zinc-400">This is a high-signal strategic asset with exceptional commercial qualities.</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
          {
            siteConfig.premiumReasons.map((reason, i) => (
              <div class="card-hover bg-zinc-950 border border-zinc-800 rounded-3xl p-8 flex flex-col">
                <div class="w-12 h-12 flex items-center justify-center rounded-2xl gold-glow bg-opacity-10 mb-6">
                  <span class="text-2xl font-extrabold font-display text-zinc-950">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <h3 class="font-semibold text-xl tracking-tight mb-3">{reason.title}</h3>
                <p class="text-zinc-400 leading-relaxed flex-grow">{reason.description}</p>
              </div>
            ))
          }
        </div>

        <div class="max-w-3xl mx-auto mt-12 text-center text-sm text-zinc-500 border-t border-zinc-800 pt-8">
          Domains carrying this level of linguistic precision, emotional resonance, and cross-category versatility are recognized as significant long-term digital assets.
        </div>
      </div>
    </section>

    <!-- IDEAL BRAND APPLICATIONS -->
    <section id="applications" class="max-w-screen-xl mx-auto px-6 pt-20 pb-16">
      <div class="max-w-3xl mx-auto text-center mb-14">
        <div class="inline-block px-4 py-1 rounded-3xl bg-emerald-400/10 text-emerald-400 text-xs font-bold tracking-[2px] mb-4">IDEAL BRAND APPLICATIONS</div>
        <h2 class="section-header tracking-[-2.5px]">Built for ventures<br />at the frontier of <span class="gold-gradient">human potential</span></h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {
          siteConfig.brandApplications.map((app, i) => (
            <div class="insight-card bg-zinc-900 border border-zinc-800 hover:border-amber-400/60 rounded-3xl p-8 flex flex-col">
              <div class="flex items-center gap-x-4 mb-5">
                <div class="w-11 h-11 rounded-2xl gold-glow flex items-center justify-center flex-shrink-0">
                  <span class="text-zinc-950 font-bold text-lg">{i + 1}</span>
                </div>
                <div>
                  <div class="font-semibold text-lg tracking-tight">{app.title}</div>
                </div>
              </div>
              <p class="text-zinc-400 flex-grow text-[15px] leading-relaxed">{app.description}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- THE OPPORTUNITY -->
    <section id="opportunity" class="bg-zinc-900 border-y border-zinc-800 py-20">
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <div class="inline-block px-4 py-1 rounded-3xl bg-amber-400/10 text-amber-400 text-xs font-bold tracking-[2px] mb-4">THE OPPORTUNITY</div>
            <h2 class="section-header tracking-[-2.5px]">The Era of<br /><span class="gold-gradient">Amplified Intelligence</span></h2>
          </div>

          <div class="prose-custom space-y-5 text-lg">
            <p>
              We are entering an era where the boundary between human and artificial intelligence is blurring, and the demand for reliable, sustainable human genius has never been higher. geniussalt.com offers <strong>immediate brand authority</strong> and a defensible position at the center of this transformation.
            </p>

            <p>
              It is the name for the organization or product line that understands: genius is not just a spark — it is a spark that must be <strong class="text-white">seasoned, grounded, preserved, and repeatedly ignited</strong> by the right foundational elements. The right salt.
            </p>
          </div>

          <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-zinc-950 border border-zinc-800 rounded-2xl p-6 text-center">
              <div class="text-4xl font-semibold text-white tracking-tighter">Peak<br/>Performance</div>
              <div class="text-sm text-zinc-400 mt-1">Biohacking &amp; Flow</div>
            </div>
            <div class="bg-zinc-950 border border-zinc-800 rounded-2xl p-6 text-center">
              <div class="text-4xl font-semibold text-white tracking-tighter">AI +<br/>Human</div>
              <div class="text-sm text-zinc-400 mt-1">Augmentation</div>
            </div>
            <div class="bg-zinc-950 border border-zinc-800 rounded-2xl p-6 text-center">
              <div class="text-4xl font-semibold text-white tracking-tighter">Creativity<br/>&amp; Innovation</div>
              <div class="text-sm text-zinc-400 mt-1">Platforms &amp; Tools</div>
            </div>
            <div class="bg-zinc-950 border border-zinc-800 rounded-2xl p-6 text-center">
              <div class="text-4xl font-semibold text-white tracking-tighter">Cognitive<br/>Mastery</div>
              <div class="text-sm text-zinc-400 mt-1">Longevity &amp; Wellness</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- THIS IS MORE THAN A DOMAIN -->
    <section class="max-w-screen-xl mx-auto px-6 py-20">
      <div class="max-w-4xl mx-auto text-center">
        <div class="mx-auto mb-8 inline-flex items-center justify-center w-20 h-20 rounded-full bg-white/5 border border-white/10">
          <i class="fa-solid fa-crown text-4xl gold-gradient"></i>
        </div>

        <h2 class="font-display text-5xl md:text-6xl tracking-[-2.5px] leading-none font-extrabold mb-6">
          This Is More Than a Domain —<br />
          <span class="gold-gradient">It's the Essential Seasoning</span>
        </h2>

        <div class="prose-custom max-w-2xl mx-auto space-y-4 text-lg">
          <p>
            In a digital landscape crowded with generic names and forgettable handles, <strong class="text-white">geniussalt.com</strong> stands apart. It is the name that positions its owner at the intersection of ancient wisdom and cutting-edge neuroscience — where the spark of genius meets the grounding science of peak human performance.
          </p>
          <p>
            Whether you are the founder building the next category-defining cognitive brand, the entrepreneur launching a platform at the frontier of human-AI collaboration, or the investor who recognizes long-term brand equity in the most valuable TLD on Earth, this domain is ready to serve as the cornerstone.
          </p>
        </div>
      </div>
    </section>

    <!-- ACQUISITION SECTION -->
    <section class="bg-zinc-900 border-y border-zinc-800 py-16">
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-10">
            <div class="inline-block px-5 py-1.5 rounded-3xl gold-glow text-zinc-950 text-xs font-extrabold tracking-[1.5px] mb-4">ACQUISITION</div>
            <h2 class="section-header tracking-[-2px]">Secure This Asset</h2>
            <p class="mt-4 text-xl text-zinc-400">geniussalt.com is available for acquisition by serious buyers seeking a distinctive, high-potential digital property.</p>
          </div>

          <div class="bg-zinc-950 border border-zinc-700 rounded-3xl p-10 md:p-14">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-y-8">
              <div>
                <div class="text-sm uppercase tracking-[3px] text-amber-400 font-bold mb-2">Premium Strategic Asset</div>
                <div class="flex items-baseline gap-x-2">
                  <span class="text-5xl font-extrabold tabular-nums tracking-[-2px]">Pricing available<br/>upon request</span>
                </div>
                <div class="text-sm text-zinc-400 mt-1">One-time acquisition • Full ownership transfer</div>

                <div class="mt-6 text-sm max-w-xs">
                  <div class="flex items-center gap-x-2 text-emerald-400">
                    <i class="fa-solid fa-check"></i>
                    <span class="font-medium">Flexible terms for qualified inquiries. Optional branding strategy consultation available.</span>
                  </div>
                </div>
              </div>

              <div class="lg:text-right">
                <AcquisitionCTA label="Submit Acquisition Inquiry" variant="accent" icon="fa-arrow-right-long" />
                <div class="mt-4 text-xs text-zinc-400">Serious buyers only • Escrow protected</div>
              </div>
            </div>

            <div class="mt-10 pt-8 border-t border-zinc-700 grid grid-cols-1 sm:grid-cols-3 gap-y-6 text-sm">
              <div>
                <div class="font-semibold mb-1 flex items-center gap-x-2"><i class="fa-solid fa-handshake text-amber-400"></i> <span>Transaction</span></div>
                <div class="text-zinc-400">Handled via Escrow.com or your preferred platform. Full domain push + DNS control transfer.</div>
              </div>
              <div>
                <div class="font-semibold mb-1 flex items-center gap-x-2"><i class="fa-solid fa-file-contract text-amber-400"></i> <span>Confidential</span></div>
                <div class="text-zinc-400">All inquiries are handled confidentially. Pricing reflects brand strength, linguistic precision, emotional resonance, and cross-category versatility.</div>
              </div>
              <div>
                <div class="font-semibold mb-1 flex items-center gap-x-2"><i class="fa-solid fa-globe text-amber-400"></i> <span>Ready to own the name that captures the essential seasoning of genius?</span></div>
                <div class="text-zinc-400">Contact us today to discuss acquisition and next steps.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <div class="bg-gradient-to-b from-zinc-900 to-zinc-950 py-16">
      <div class="max-w-screen-xl mx-auto px-6 text-center">
        <div class="max-w-lg mx-auto">
          <h3 class="font-display text-5xl tracking-[-2px] font-extrabold mb-4">Genius has<br />a new name.</h3>
          <p class="text-xl text-zinc-300 mb-8">Claim the premium domain that defines the essential seasoning of exceptional minds.</p>

          <AcquisitionCTA label="Inquire to Acquire" variant="accent" />
        </div>
      </div>
    </div>
  </main>

  <Footer disclaimer={siteConfig.disclaimer} />
</BaseLayout>
